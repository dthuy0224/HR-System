<!DOCTYPE html>
<html lang="en">
<head>
  <meta name="csrf-token" content="<%= csrfToken %>">
  <title><%= typeof title !== "undefined" ? title : "Forgot Password" %></title>
  <link rel="stylesheet" href="/stylesheets/forgot-password.css" />
</head>
<body>
  <div class="forgot-password-container">
    <h1>Forgot Password</h1>

    <% if (messages && messages.length > 0) { %>
      <div class="error-message">
        <% messages.forEach(function (msg) { %>
          <p class="error-text"><%= msg %></p>
        <% }); %>
      </div>
    <% } %>

    <form id="forgotPasswordForm" method="POST" action="/forgot-password">
      <label for="email">Email Address:</label>
      <input type="email" id="email" name="email" placeholder="Enter Your Work Email Address" required />

      <input type="hidden" id="csrfToken" name="_csrf" value="<%= csrfToken %>">

      <!-- 🔥 Thêm phần tử hiển thị thông báo -->
      <p id="message" class="hidden-message"></p>

      <div class="button-group">
        <button type="submit">Submit</button>
        <button type="button" class="cancel-btn" id="cancelButton">Cancel</button>
      </div>
    </form>

    <p class="help-link">Need help? Visit our <a href="#">help center</a></p>
  </div>

  <script src="/javascripts/forgot-password.js"></script>
</body>
</html>
